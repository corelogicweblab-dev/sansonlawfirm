{
  "name": "sanson-legal-os",
  "version": "1.0.0",
  "private": true,
  "description": "SANSON Law Firm — AI-powered Legal Operating System",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace=@sanson/web",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8100",
    "build": "npm run build --workspace=@sanson/web",
    "build:web": "npm run build --workspace=@sanson/web",
    "lint": "npm run lint --workspace=@sanson/web --if-present",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
