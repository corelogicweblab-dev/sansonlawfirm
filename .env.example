# =============================================================================
# SANSON Legal OS — Environment Configuration
# Alternate ports (3100 / 8100) — less conflict with other apps
# =============================================================================

# --- Ports (change here if still in use) ---
WEB_PORT=3100
API_PORT=8100
POSTGRES_PORT=5433
REDIS_PORT=6380
QDRANT_PORT=6335
MINIO_PORT=9010
MINIO_CONSOLE_PORT=9011

# --- Application ---
NODE_ENV=development
APP_NAME=SANSON Legal OS
APP_URL=http://localhost:3100
API_URL=http://localhost:8100
API_VERSION=v1

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_USER=sanson
POSTGRES_PASSWORD=sanson_dev_password
POSTGRES_DB=sanson_legal
DATABASE_URL=postgresql+asyncpg://sanson:sanson_dev_password@localhost:5433/sanson_legal

# --- Redis ---
REDIS_URL=redis://localhost:6380/0

# --- JWT / Security ---
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Ollama (optional local AI) ---
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Qdrant ---
QDRANT_URL=http://localhost:6335
QDRANT_API_KEY=
QDRANT_COLLECTION=sanson_documents

# --- AWS S3 Compatible Storage ---
S3_ENDPOINT=http://localhost:9010
S3_ACCESS_KEY=sanson_minio
S3_SECRET_KEY=sanson_minio_secret
S3_BUCKET=sanson-documents
S3_REGION=us-east-1
S3_USE_SSL=false

# --- Firebase (FCM) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- GCash Payments (optional) ---
GCASH_ENABLED=false
GCASH_MERCHANT_ID=
GCASH_WEBHOOK_SECRET=

# --- CORS (must include web port) ---
CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100,http://localhost:8081

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Next.js (Web) ---
NEXT_PUBLIC_API_URL=http://localhost:8100
NEXT_PUBLIC_WS_URL=ws://localhost:8100
NEXT_PUBLIC_APP_NAME=SANSON Legal OS

# --- Expo (Mobile) — use your PC LAN IP when testing on phone ---
EXPO_PUBLIC_API_URL=http://localhost:8100
EXPO_PUBLIC_WS_URL=ws://localhost:8100
